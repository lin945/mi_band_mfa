<template>
  <div class="page" onswipe="handleSwipe">
    <div class="hero">
      <text class="issuer">{{ token.issuer }}</text>
      <text class="account">{{ token.accountName }}</text>
      <text class="code">{{ token.groupedCode }}</text>
      <text class="time">剩余 {{ token.remaining }} 秒</text>
    </div>

    <div class="detail-card">
      <div class="detail-row">
        <text class="label">状态</text>
        <text class="value">{{ token.status }}</text>
      </div>
      <div class="detail-row">
        <text class="label">算法</text>
        <text class="value">{{ token.algorithm }}</text>
      </div>
      <div class="detail-row">
        <text class="label">位数</text>
        <text class="value">{{ token.digits }}</text>
      </div>
      <div class="detail-row">
        <text class="label">周期</text>
        <text class="value">{{ token.period }}s</text>
      </div>
      <div class="detail-row">
        <text class="label">Secret</text>
        <text class="value">{{ token.maskedSecret }}</text>
      </div>
    </div>

    <text class="hint">右滑返回</text>
  </div>
</template>

<script>
import router from "@system.router"
import { buildTokenState } from "../../common/scripts/totp"
import { loadMfaAccounts, findAccountById } from "../../common/scripts/mfaConfig"

export default {
  protected: {
    id: ""
  },

  private: {
    account: null,
    token: {
      issuer: "",
      accountName: "",
      groupedCode: "--- ---",
      remaining: 30,
      status: "可用",
      period: 30,
      digits: 6,
      algorithm: "SHA1",
      maskedSecret: "----"
    },
    timer: null
  },

  onInit() {
    loadMfaAccounts(accounts => {
      this.account = findAccountById(accounts, this.id)
      this.refreshToken()
    })
  },

  onShow() {
    this.refreshToken()
    this.startTicker()
  },

  onHide() {
    this.stopTicker()
  },

  onDestroy() {
    this.stopTicker()
  },

  startTicker() {
    if (this.timer) {
      return
    }
    this.timer = setInterval(() => {
      this.refreshToken()
    }, 1000)
  },

  stopTicker() {
    if (!this.timer) {
      return
    }
    clearInterval(this.timer)
    this.timer = null
  },

  refreshToken() {
    if (!this.account) {
      return
    }
    const nextToken = buildTokenState(this.account)
    this.token = {
      issuer: nextToken.issuer,
      accountName: nextToken.accountName,
      groupedCode: nextToken.groupedCode,
      remaining: nextToken.remaining,
      status: nextToken.status,
      period: nextToken.period,
      digits: nextToken.digits,
      algorithm: this.account.algorithm || "SHA1",
      maskedSecret: this.maskSecret(this.account.secret)
    }
  },

  maskSecret(secret) {
    if (!secret) {
      return "----"
    }
    const value = String(secret)
    if (value.length <= 8) {
      return "********"
    }
    return `${value.slice(0, 4)}...${value.slice(value.length - 4)}`
  },

  handleSwipe(event) {
    if (event.direction === "right") {
      router.back()
    }
  }
}
</script>

