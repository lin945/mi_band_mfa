  width: 100%;
  height: 100%;
  flex-direction: column;
  align-items: center;
  background-color: #f7f4e9;
  padding-top: 22px;
  padding-bottom: 12px;
}

.hero {
  width: 82%;
  flex-direction: column;
  align-items: center;
  padding: 14px;
  border-radius: 24px;
  background-color: #ffffff;
}

.issuer {
  color: #23322c;
  font-size: 24px;
  font-weight: bold;
  text-align: center;
}

.account {
  margin-top: 6px;
  color: #66736c;
  font-size: 13px;
  text-align: center;
}

.code {
  margin-top: 18px;
  color: #0f8f6b;
  font-size: 44px;
  font-weight: bold;
  text-align: center;
}

.time {
  margin-top: 10px;
  color: #42695d;
  font-size: 16px;
  text-align: center;
}

.detail-card {
  width: 82%;
  margin-top: 10px;
  padding: 12px;
  flex-direction: column;
  border-radius: 22px;
  background-color: #ffffff;
}

.detail-row {
  width: 100%;
  height: 34px;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.label {
  color: #66736c;
  font-size: 12px;
}

.value {
  color: #23322c;
  font-size: 13px;
  text-align: right;
}

.hint {
  margin-top: 12px;
  color: #7a857f;
  font-size: 11px;
  text-align: center;
}
</style>
