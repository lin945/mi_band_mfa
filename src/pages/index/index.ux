  color: #23322c;
  font-size: 16px;
  font-weight: bold;
  text-align: center;
}

.control-center {
  flex: 1;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.control-label {
  color: #7a857f;
  font-size: 10px;
}

.control-value {
  margin-left: 8px;
  color: #23322c;
  font-size: 11px;
  font-weight: bold;
  text-align: center;
}

.token-list {
  width: 82%;
  height: 318px;
  margin-top: 8px;
}

.empty-card {
  width: 82%;
  height: 136px;
  padding: 14px;
  margin-top: 10px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 22px;
  background-color: #ffffff;
}

.empty-title {
  color: #23322c;
  font-size: 19px;
  font-weight: bold;
  text-align: center;
}

.empty-copy {
  margin-top: 8px;
  color: #66736c;
  font-size: 11px;
  text-align: center;
}

.token-item {
  width: 100%;
  height: 104px;
}

.token-card {
  width: 100%;
  height: 96px;
  padding: 10px 12px;
  flex-direction: column;
  justify-content: center;
  border-radius: 20px;
  background-color: #ffffff;
}

.token-head {
  width: 100%;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.issuer {
  width: 150px;
  color: #23322c;
  font-size: 16px;
  font-weight: bold;
  text-align: left;
  lines: 1;
  text-overflow: ellipsis;
}

.time {
  margin-left: 8px;
  color: #42695d;
  font-size: 11px;
  font-weight: bold;
  text-align: right;
}

.account {
  width: 100%;
  margin-top: 4px;
  color: #66736c;
  font-size: 10px;
  text-align: left;
  lines: 1;
  text-overflow: ellipsis;
}

.code {
  width: 100%;
  margin-top: 6px;
