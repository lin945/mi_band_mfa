<template>
  <div class="page">
    <div class="header">
      <text class="title">MFA Codes</text>
      <text class="subtitle">{{ accounts.length }} tokens · local</text>
    </div>

    <scroll class="token-scroll" scroll-y="true">
      <div class="token-card" for="{{ accounts }}" tid="id" onclick="openDetail($item.id)">
        <div class="token-main">
          <text class="issuer">{{ $item.issuer }}</text>
          <text class="account">{{ $item.accountName }}</text>
          <text class="code">{{ $item.groupedCode }}</text>
        </div>
        <div class="token-side">
          <text class="time">{{ $item.remaining }}s</text>
          <text class="status">{{ $item.status }}</text>
        </div>
      </div>
    </scroll>

    <div class="footer">
      <text class="hint">Tap a token for large view</text>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import { MFA_ACCOUNTS, buildTokenState } from "../../common/scripts/totp"

export default {
  private: {
    accounts: [],
    timer: null
  },

  onInit() {
    this.accounts = MFA_ACCOUNTS.map(account => buildTokenState(account))
  },

  onShow() {
    this.refreshTokens()
    this.startTicker()
  },

  onHide() {
    this.stopTicker()
  },

  onDestroy() {
    this.stopTicker()
  },

  startTicker() {
    if (this.timer) {
      return
    }
    this.timer = setInterval(() => {
      this.refreshTokens()
    }, 1000)
  },

  stopTicker() {
    if (!this.timer) {
      return
    }
    clearInterval(this.timer)
    this.timer = null
  },

  refreshTokens() {
    const now = Date.now()
    for (let index = 0; index < MFA_ACCOUNTS.length; index++) {
      const nextState = buildTokenState(MFA_ACCOUNTS[index], now)
      this.accounts[index].code = nextState.code
      this.accounts[index].groupedCode = nextState.groupedCode
      this.accounts[index].remaining = nextState.remaining
      this.accounts[index].progress = nextState.progress
      this.accounts[index].status = nextState.status
    }
  },

  openDetail(id) {
    router.push({
      uri: "/pages/detail",
      params: {
        id
      }
    })
  }
}
</script>

