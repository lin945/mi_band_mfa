  flex-direction: column;
  background-color: #050505;
  padding: 16px;
}

.header {
  flex-direction: column;
  align-items: center;
  margin-bottom: 12px;
}

.title {
  color: #ffffff;
  font-size: 24px;
  font-weight: bold;
  text-align: center;
}

.subtitle {
  margin-top: 4px;
  color: #9aa3aa;
  font-size: 12px;
  text-align: center;
}

.token-scroll {
  width: 100%;
  height: 360px;
}

.token-card {
  width: 100%;
  height: 112px;
  margin-bottom: 10px;
  padding: 12px;
  flex-direction: row;
  justify-content: space-between;
  border-radius: 16px;
  background-color: #152026;
}

.token-main {
  flex: 1;
  flex-direction: column;
}

.issuer {
  color: #ffffff;
  font-size: 17px;
  font-weight: bold;
}

.account {
  margin-top: 2px;
  color: #9aa3aa;
  font-size: 11px;
}

.code {
  margin-top: 10px;
  color: #7df7c2;
  font-size: 28px;
  font-weight: bold;
}

.token-side {
  width: 52px;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.time {
  color: #ffffff;
  font-size: 20px;
  font-weight: bold;
}

.status {
  margin-top: 6px;
  color: #9aa3aa;
  font-size: 9px;
  text-align: right;
}

.footer {
  align-items: center;
  padding-top: 8px;
}

.hint {
  color: #6f7d86;
  font-size: 11px;
  text-align: center;
}
</style>
