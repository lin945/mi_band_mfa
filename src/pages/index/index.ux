<template>
  <div class="page">
    <div class="header">
      <text class="title">MFA Codes</text>
      <text class="subtitle">{{ accounts.length }} tokens · {{ phoneStatus }}</text>
    </div>

    <scroll class="token-scroll" scroll-y="true">
      <div class="empty-card" show="{{ accounts.length === 0 }}">
        <text class="empty-title">No tokens</text>
        <text class="empty-copy">Sync configs from phone</text>
      </div>
      <div class="token-card" for="{{ accounts }}" tid="id" onclick="openDetail($item.id)">
        <div class="token-main">
          <text class="issuer">{{ $item.issuer }}</text>
          <text class="account">{{ $item.accountName }}</text>
          <text class="code">{{ $item.groupedCode }}</text>
        </div>
        <div class="token-side">
          <text class="time">{{ $item.remaining }}s</text>
          <text class="status">{{ $item.status }}</text>
        </div>
      </div>
    </scroll>

    <div class="footer">
      <text class="hint">{{ syncStatus }}</text>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import interconnect from "@system.interconnect"
import { buildTokenState } from "../../common/scripts/totp"
import { loadMfaAccounts, saveMfaAccounts, parseConfigSnapshot } from "../../common/scripts/mfaConfig"

let phoneConnection = null

export default {
  private: {
    rawAccounts: [],
    accounts: [],
    phoneStatus: "local",
    syncStatus: "Waiting for phone sync",
    timer: null
  },

  onInit() {
    this.loadAccounts()
    this.setupPhoneChannel()
  },

  onShow() {
    this.refreshTokens()
    this.startTicker()
  },

  onHide() {
    this.stopTicker()
  },

  onDestroy() {
    this.stopTicker()
  },

  loadAccounts() {
    loadMfaAccounts(accounts => {
      this.rawAccounts = accounts
      this.accounts = accounts.map(account => buildTokenState(account))
      this.refreshTokens()
    })
  },

  setupPhoneChannel() {
    try {
      phoneConnection = interconnect.instance()
      phoneConnection.onopen = () => {
        this.phoneStatus = "phone connected"
      }
      phoneConnection.onclose = () => {
        this.phoneStatus = "phone disconnected"
      }
      phoneConnection.onerror = () => {
        this.phoneStatus = "phone error"
      }
      phoneConnection.onmessage = message => {
        this.handlePhoneMessage(message)
      }
    } catch (error) {
      this.phoneStatus = "local only"
    }
  },

  handlePhoneMessage(message) {
    const payload = this.extractPayload(message)
    const snapshot = parseConfigSnapshot(payload)
    if (!snapshot) {
      return
    }

    saveMfaAccounts(snapshot.configs, saved => {
      this.rawAccounts = snapshot.configs
      this.accounts = snapshot.configs.map(account => buildTokenState(account))
      this.refreshTokens()
      this.phoneStatus = "synced"
      this.syncStatus = saved ? `Synced ${snapshot.configs.length} tokens` : "Sync received but save failed"
    })
  },

  extractPayload(message) {
    if (!message) {
      return ""
    }
    if (typeof message === "string") {
      return message
    }
    if (message.data) {
      return message.data
    }
    return String(message)
  },

  startTicker() {
    if (this.timer) {
      return
    }
    this.timer = setInterval(() => {
      this.refreshTokens()
    }, 1000)
  },

  stopTicker() {
    if (!this.timer) {
      return
    }
    clearInterval(this.timer)
    this.timer = null
  },

  refreshTokens() {
    const now = Date.now()
    for (let index = 0; index < this.rawAccounts.length; index++) {
      const nextState = buildTokenState(this.rawAccounts[index], now)
      if (!this.accounts[index]) {
        this.accounts[index] = nextState
      } else {
        this.accounts[index].code = nextState.code
        this.accounts[index].groupedCode = nextState.groupedCode
        this.accounts[index].remaining = nextState.remaining
        this.accounts[index].progress = nextState.progress
        this.accounts[index].status = nextState.status
      }
    }
  },

  openDetail(id) {
    router.push({
      uri: "/pages/detail",
      params: {
        id
      }
    })
  }
}
</script>

