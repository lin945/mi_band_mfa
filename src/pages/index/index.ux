<template>
  <div class="page">
    <div class="header">
      <text class="title" onclick="openCopyright">BandOTP</text>
      <text class="subtitle">{{ rawAccounts.length }} 个 · {{ phoneStatus }}</text>
      <text class="header-hint">点击标题查看版权与赞助</text>
    </div>

    <div class="control-card" if="{{ rawAccounts.length > 0 }}">
      <div class="control-row">
        <div class="nav-button" onclick="prevCategory">
          <text class="nav-text"><</text>
        </div>
        <div class="control-center">
          <text class="control-label">分类</text>
          <text class="control-value">{{ currentCategoryLabel }}</text>
        </div>
        <div class="nav-button" onclick="nextCategory">
          <text class="nav-text">></text>
        </div>
      </div>
      <div class="control-row row-gap">
        <div class="nav-button page-button" onclick="prevPage">
          <text class="nav-text"><</text>
        </div>
        <div class="control-center">
          <text class="control-label">分页</text>
          <text class="control-value">{{ currentPage + 1 }}/{{ totalPages }}</text>
        </div>
        <div class="nav-button page-button" onclick="nextPage">
          <text class="nav-text">></text>
        </div>
      </div>
    </div>

    <div class="empty-card" if="{{ rawAccounts.length === 0 }}">
      <text class="empty-title">未导入验证码</text>
      <text class="empty-copy">请在安卓端新增 MFA 配置后同步到手环</text>
    </div>

    <list class="token-list" bounces="true" if="{{ rawAccounts.length > 0 }}">
      <list-item class="token-item" for="{{ accounts }}" tid="id" type="token-item" onclick="openDetail($item.id)">
        <div class="token-card">
          <div class="token-head">
            <text class="issuer">{{ $item.issuer }}</text>
            <text class="time">{{ $item.remaining }}s</text>
          </div>
          <text class="account">{{ $item.accountName }}</text>
          <text class="code">{{ $item.groupedCode }}</text>
          <text class="meta">{{ $item.digits }}位 · {{ $item.period }}秒 · {{ $item.status }}</text>
        </div>
      </list-item>
    </list>

    <div class="footer">
      <text class="hint">{{ syncStatus }}</text>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import interconnect from "@system.interconnect"
import { buildTokenState } from "../../common/scripts/totp"
import {
  DEFAULT_CATEGORY,
  loadMfaAccounts,
  saveMfaAccounts,
  parseConfigSnapshot
} from "../../common/scripts/mfaConfig"

const PAGE_SIZE = 3
let phoneConnection = null

export default {
  private: {
    rawAccounts: [],
    accounts: [],
    categories: [],
    currentCategory: DEFAULT_CATEGORY,
    currentCategoryLabel: DEFAULT_CATEGORY,
    currentPage: 0,
    totalPages: 1,
    phoneStatus: "本地",
    syncStatus: "等待安卓端同步",
    timer: null
  },

  onInit() {
    this.loadAccounts()
    this.setupPhoneChannel()
  },

  onShow() {
    this.refreshTokens()
    this.startTicker()
  },

  onHide() {
    this.stopTicker()
  },

  onDestroy() {
    this.stopTicker()
  },

  loadAccounts() {
    loadMfaAccounts(accounts => {
      this.rawAccounts = accounts
      this.resetVisibleState(this.currentCategory, this.currentPage)
    })
  },

  setupPhoneChannel() {
    try {
      phoneConnection = interconnect.instance()
      phoneConnection.onopen = () => {
        this.phoneStatus = "已连接手机"
      }
      phoneConnection.onclose = () => {
        this.phoneStatus = "手机断开"
      }
      phoneConnection.onerror = () => {
        this.phoneStatus = "连接异常"
      }
      phoneConnection.onmessage = message => {
        this.handlePhoneMessage(message)
      }
    } catch (error) {
      this.phoneStatus = "仅本地"
    }
  },

  handlePhoneMessage(message) {
    const payload = this.extractPayload(message)
    const snapshot = parseConfigSnapshot(payload)
    if (!snapshot) {
      return
    }

    saveMfaAccounts(snapshot.configs, saved => {
      this.rawAccounts = snapshot.configs
      this.phoneStatus = "已同步"
      this.syncStatus = saved ? `已导入 ${snapshot.configs.length} 个验证码` : "已接收配置但保存失败"
      this.resetVisibleState(this.currentCategory, 0)
    })
  },

  extractPayload(message) {
    if (!message) {
      return ""
    }
    if (typeof message === "string") {
      return message
    }
    if (message.data) {
      return message.data
    }
    return String(message)
  },

  startTicker() {
    if (this.timer) {
      return
    }
    this.timer = setInterval(() => {
      this.refreshTokens()
    }, 1000)
  },

  stopTicker() {
    if (!this.timer) {
      return
    }
    clearInterval(this.timer)
    this.timer = null
  },

  refreshTokens() {
    this.updateVisiblePage(this.currentPage, Date.now())
  },

  resetVisibleState(preferredCategory, preferredPage) {
    this.categories = this.collectCategories(this.rawAccounts)
    if (this.categories.length === 0) {
      this.currentCategory = DEFAULT_CATEGORY
      this.currentCategoryLabel = DEFAULT_CATEGORY
      this.currentPage = 0
      this.totalPages = 1
      this.accounts = []
      return
    }

    const nextCategory = this.hasCategory(preferredCategory) ? preferredCategory : this.categories[0]
    this.currentCategory = nextCategory
    this.currentCategoryLabel = this.formatCategoryLabel(nextCategory)
    this.updateVisiblePage(preferredPage, Date.now())
  },

  collectCategories(accounts) {
    const categories = []
    const seen = {}
    for (let index = 0; index < accounts.length; index++) {
      const category = accounts[index].category || DEFAULT_CATEGORY
      if (!seen[category]) {
        seen[category] = true
        categories.push(category)
      }
    }
    return categories
  },

  hasCategory(category) {
    for (let index = 0; index < this.categories.length; index++) {
      if (this.categories[index] === category) {
        return true
      }
    }
    return false
  },

  getAccountsForCategory(category) {
    const accounts = []
    for (let index = 0; index < this.rawAccounts.length; index++) {
      const account = this.rawAccounts[index]
      if ((account.category || DEFAULT_CATEGORY) === category) {
        accounts.push(account)
      }
    }
    return accounts
  },

  updateVisiblePage(page, now) {
    const categoryAccounts = this.getAccountsForCategory(this.currentCategory)
    this.totalPages = Math.max(1, Math.ceil(categoryAccounts.length / PAGE_SIZE))

    let nextPage = Number(page)
    if (isNaN(nextPage)) {
      nextPage = 0
    }
    if (nextPage < 0) {
      nextPage = 0
    }
    if (nextPage > this.totalPages - 1) {
      nextPage = this.totalPages - 1
    }

    this.currentPage = nextPage
    const start = nextPage * PAGE_SIZE
    const visibleAccounts = categoryAccounts.slice(start, start + PAGE_SIZE)
    const currentTime = now || Date.now()
    this.accounts = visibleAccounts.map(account => buildTokenState(account, currentTime))
  },

  formatCategoryLabel(category) {
    if (!category) {
      return DEFAULT_CATEGORY
    }
    return category.length > 8 ? `${category.slice(0, 8)}...` : category
  },

  prevCategory() {
    this.switchCategory(-1)
  },

  nextCategory() {
    this.switchCategory(1)
  },

  switchCategory(step) {
    if (this.categories.length === 0) {
      return
    }

    let index = 0
    for (let cursor = 0; cursor < this.categories.length; cursor++) {
      if (this.categories[cursor] === this.currentCategory) {
        index = cursor
        break
      }
    }

    const nextIndex = (index + step + this.categories.length) % this.categories.length
    const nextCategory = this.categories[nextIndex]
    this.currentCategory = nextCategory
    this.currentCategoryLabel = this.formatCategoryLabel(nextCategory)
    this.updateVisiblePage(0, Date.now())
  },

  prevPage() {
    this.switchPage(-1)
  },

  nextPage() {
    this.switchPage(1)
  },

  switchPage(step) {
    if (this.totalPages <= 1) {
      this.updateVisiblePage(0, Date.now())
      return
    }

    let nextPage = this.currentPage + step
    if (nextPage < 0) {
      nextPage = this.totalPages - 1
    }
    if (nextPage >= this.totalPages) {
      nextPage = 0
    }
    this.updateVisiblePage(nextPage, Date.now())
  },

  openDetail(id) {
    router.push({
      uri: "/pages/detail",
      params: {
        id
      }
    })
  },

  openCopyright() {
    router.push({
      uri: "/pages/copyright"
    })
  }
}
</script>

